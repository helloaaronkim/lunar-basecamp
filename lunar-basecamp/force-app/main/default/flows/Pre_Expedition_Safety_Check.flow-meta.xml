            </value>
        </inputParameters>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Status_Changed_To_Confirmed</name>
        <label>Status Changed To Confirmed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Confirmed_On_Update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Confirmed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Confirmed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Coordinator</targetReference>
            </connector>
            <label>Confirmed On Update</label>
        </rules>
    </decisions>
    <decisions>
        <name>All_Compliance_Checks_Passed</name>
        <label>All Compliance Checks Passed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Booking_Blocked</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Compliance Failed</defaultConnectorLabel>
        <rules>
            <name>All_Clear</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Basic_EVA.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Crater_Navigation.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Solar_Radiation_Protocol.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Explorer.Medical_Clearance_Date__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Ninety_Days_Ago</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Booking_Cleared</targetReference>
            </connector>
            <label>All Clear</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>Ninety_Days_Ago</name>
        <dataType>Date</dataType>
        <expression>$Flow.CurrentDate - 90</expression>
    </formulas>
    <formulas>
        <name>Email_Subject</name>
        <dataType>String</dataType>
        <expression>"Pre-Expedition Safety Check Failed: " &amp; {!$Record.Expedition_Name__c}</expression>
    </formulas>
    <formulas>
        <name>Failure_Details</name>
        <dataType>String</dataType>
        <expression>"Expedition: " &amp; {!$Record.Expedition_Name__c} &amp; BR() &amp;
"Explorer: " &amp; {!Get_Explorer.Full_Name__c} &amp; BR() &amp;
"Compliance check failed for the following reasons:" &amp; BR() &amp;
IF(ISBLANK({!Get_Basic_EVA.Id}), " - Basic EVA certification is missing or expired." &amp; BR(), "") &amp;
IF(ISBLANK({!Get_Crater_Navigation.Id}), " - Crater Navigation certification is missing or expired." &amp; BR(), "") &amp;
IF(ISBLANK({!Get_Solar_Radiation_Protocol.Id}), " - Solar Radiation Protocol certification is missing or expired." &amp; BR(), "") &amp;
IF({!Get_Explorer.Medical_Clearance_Date__c} &lt; {!Ninety_Days_Ago}, " - Medical clearance date is older than 90 days." &amp; BR(), "")</expression>
    </formulas>
    <interviewLabel>Pre Expedition Safety Check {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Pre Expedition Safety Check</label>
